<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#111111">

    <TextView
        android:id="@+id/txt_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/p2p_title"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/txt_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/p2p_state_ready"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="10dp"
        android:background="#80000000"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txt_tracking"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/p2p_tracking_unknown"
        android:textColor="#B0B0B0"
        android:textSize="13sp"
        android:padding="8dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/txt_state"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <LinearLayout
        android:id="@+id/layout_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#80000000"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/txt_tracking"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/txt_span"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p2p_span_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txt_sigma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p2p_sigma_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/txt_hits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p2p_hits_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/txt_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p2p_grid_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/txt_hit_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p2p_hit_type_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/p2p_mode_label"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:gravity="center_vertical" />

            <RadioGroup
                android:id="@+id/radio_axis_mode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_mode_xyz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/p2p_mode_xyz"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:checked="true"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <RadioButton
                    android:id="@+id/radio_mode_xz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/p2p_mode_xz"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </RadioGroup>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txt_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/p2p_distance_placeholder"
        android:textColor="#4CAF50"
        android:textSize="64sp"
        android:textStyle="bold"
        android:gravity="center"
        android:includeFontPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="18dp" />

    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="18dp">

        <Button
            android:id="@+id/btn_set_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/p2p_btn_set_start"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btn_set_end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/p2p_btn_set_end"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FF5722"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_reset"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/p2p_btn_reset"
        android:textSize="16sp"
        android:padding="12dp"
        android:backgroundTint="#9E9E9E"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>

