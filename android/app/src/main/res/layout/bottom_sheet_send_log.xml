<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="24dp">

    <TextView
        android:id="@+id/txt_send_log_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_send_log_title"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txt_send_log_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_send_log_body"
        android:textColor="#CFCFCF"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_send_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_btn_send_log"
        android:textSize="15sp"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_cancel_send_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_cancel"
        android:textSize="14sp"
        android:backgroundTint="#3A3A3A"
        android:textColor="@android:color/white"
        android:layout_marginTop="10dp" />

</LinearLayout>

